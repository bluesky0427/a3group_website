# =============================================================================
# A3 Technology Group — Environment Variables (EXAMPLE)
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` for local development:
#     cp .env.example .env.local
#
# On Vercel, add these same keys under:
#     Project → Settings → Environment Variables
#
# IMPORTANT: Never commit real API keys. `.env.local` and `.env` are gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Resend — transactional email service (https://resend.com)
# -----------------------------------------------------------------------------
# 1. Create a free account at https://resend.com
# 2. Verify your sending domain (a3technologygroup.com) in the Resend dashboard.
#    Resend will give you DNS records to add. These are SENDING records
#    (typically a CNAME for DKIM and a TXT for SPF on a subdomain like
#    "send.a3technologygroup.com"). Add them WITHOUT removing your existing
#    Google Workspace MX / SPF / DKIM / DMARC records. (See README.)
# 3. Create an API key (API Keys → Create) and paste it below.
RESEND_API_KEY=re_your_real_api_key_here

# -----------------------------------------------------------------------------
# Email addresses used by the contact form API route
# -----------------------------------------------------------------------------
# Where the internal notification (a new contact submission) is delivered.
CONTACT_TO_EMAIL=support@a3technologygroup.com

# The "from" address for the internal notification email.
# Must be on a domain you have verified in Resend.
CONTACT_FROM_EMAIL=no-reply@a3technologygroup.com

# The "from" address for the automatic thank-you email sent to the visitor.
CONTACT_THANK_YOU_FROM_EMAIL=no-reply@a3technologygroup.com

# -----------------------------------------------------------------------------
# Public site URL — used for canonical URLs, sitemap, and SEO metadata.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://a3technologygroup.com
